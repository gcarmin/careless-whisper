{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Careless Whisper",
  "version": "0.5.6",
  "identifier": "com.whispertap.careless-whisper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "Settings",
        "width": 600,
        "height": 800,
        "visible": false,
        "resizable": false,
        "decorations": true
      },
      {
        "label": "overlay",
        "title": "",
        "width": 320,
        "height": 80,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "focus": false,
        "x": 0,
        "y": 40
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: tauri:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: tauri: https://huggingface.co"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libasound2",
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libappindicator3-1",
          "xdotool",
          "wtype",
          "ydotool"
        ]
      },
      "rpm": {
        "depends": [
          "alsa-lib",
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3",
          "xdotool",
          "wtype",
          "ydotool"
        ],
        "recommends": ["kdotool"],
        "release": "1",
        "postInstallScript": "rpm/scripts/postinstall.sh",
        "postRemoveScript": "rpm/scripts/postremove.sh"
      }
    }
  }
}
